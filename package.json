{
  "name": "tvcarlos-platform",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint site qa playwright.config.js --max-warnings=0",
    "lint:api-docs": "redocly lint docs/openapi.yaml",
    "typecheck": "npm --prefix api run typecheck",
    "test:api": "npm --prefix api test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "quality": "npm run lint && npm run lint:api-docs && npm run typecheck && npm run test:api && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@redocly/cli": "2.34.0",
    "eslint": "10.5.0",
    "globals": "17.6.0"
  }
}

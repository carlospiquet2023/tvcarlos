    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/formbody": "8.0.2",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "11.0.0",
    "@node-rs/argon2": "2.0.2",
    "fastify": "5.8.5",
    "file-type": "22.0.1",
    "kysely": "0.29.2",
    "pg": "8.22.0",
    "sharp": "0.35.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "@types/pg": "8.15.5",
    "@vitest/coverage-v8": "4.1.9",
    "tsx": "4.20.5",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }

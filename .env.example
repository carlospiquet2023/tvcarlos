NODE_ENV=production
APP_ORIGIN=http://localhost:8082
PORT=3000
DATABASE_URL=postgres://tvcarlos:troque-esta-senha@database:5432/tvcarlos
POSTGRES_DB=tvcarlos
POSTGRES_USER=tvcarlos
POSTGRES_PASSWORD=troque-esta-senha
SESSION_TTL_MINUTES=120
COOKIE_SECURE=false
# Obrigatória em instalação nova. Mínimo de 14 caracteres; remova após o primeiro boot.
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=
IMAGE_STORAGE_DIR=/data/images
VIDEO_STORAGE_DIR=/data/videos
DOCUMENT_STORAGE_DIR=/data/documents
LOG_LEVEL=info
# Gere cada chave com: openssl rand -hex 32
RTMP_STREAM_KEY=
LOOP_STREAM_KEY=

# Integração com Cloudflare R2 (opcional, substitui armazenamento local se preenchido)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
